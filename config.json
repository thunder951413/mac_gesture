{
  "gestures": [
    {
      "name": "三指下滑关闭窗口",
      "fingers": 3,
      "direction": "down",
      "minDistance": 0.15,
      "keys": ["cmd", "w"]
    }
  ],
  "hotkeys": [
    {
      "name": "Ctrl+Shift+A → Cmd+C",
      "when": ["ctrl", "shift", "a"],
      "send": ["cmd", "c"]
    },
    {
      "name": "Ctrl+Shift+X → Cmd+V",
      "when": ["ctrl", "shift", "x"],
      "send": ["cmd", "v"]
    },
    {
      "name": "Ctrl+Option+Delete → Esc",
      "when": ["ctrl", "option", "delete"],
      "send": ["escape"]
    },
    {
      "name": "Cmd+H → Left",
      "when": ["cmd", "h"],
      "send": ["left"]
    },
    {
      "name": "Cmd+J → Down",
      "when": ["cmd", "j"],
      "send": ["down"]
    },
    {
      "name": "Cmd+K → Up",
      "when": ["cmd", "k"],
      "send": ["up"]
    },
    {
      "name": "Cmd+L → Right",
      "when": ["cmd", "l"],
      "send": ["right"]
    }
  ],
  "settings": {
    "debounceMs": 150,
    "logLevel": "info"
  }
}
